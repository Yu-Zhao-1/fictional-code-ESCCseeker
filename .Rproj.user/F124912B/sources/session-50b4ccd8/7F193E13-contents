# 蒙特卡洛模拟函数
monte_carlo_screening_simulation <- function(data,n_simulations, population_size) {
  # 存储结果的列表
  results <- list()
  # 筛查策略
  strategies <- as.character(data$strategy)
  for(strategy in strategies) {
    # 存储每次模拟的结果
    strategy_results <- data.frame(
      TP = numeric(n_simulations),  # 真阳性
      FP = numeric(n_simulations),  # 假阳性
      TN = numeric(n_simulations),  # 真阴性
      FN = numeric(n_simulations),  # 假阴性
      PPV = numeric(n_simulations), # 阳性预测值
      NPV = numeric(n_simulations),
      sensitivity = numeric(n_simulations),
      specificity = numeric(n_simulations)
    )
    colnames(data)=c("strategy","sen","sen_sd","spe","spe_sd")
    se=as.matrix(data[data$strategy==strategy,-1])
    for(i in 1:n_simulations) {
      eta <- rbeta(1, 15, 11)   # 依从性参数
      n_screened <- rbinom(1, population_size, eta)
      psi <- rbeta(1, 9.1, 990.9)  # 疾病患病率
      
      # 3. 抽取敏感性和特异性
      sensitivity <- rnorm(1, se[1], sqrt(se[2]))
      sensitivity <- max(0, min(1, sensitivity))  # 截断到[0,1]
      
      # 特异性
      specificity <- rnorm(1, se[3], sqrt(se[4]))
      specificity <- max(0, min(1, specificity))  # 截断到[0,1]
      # 4. 生成疾病状态和筛查结果
      # 疾病状态
      disease_status <- rbinom(n_screened, 1, psi)
      
      # 筛查结果
      screening_result <- numeric(n_screened)
      for(j in 1:n_screened) {
        if(disease_status[j] == 1) {
          # 有疾病：基于敏感性
          screening_result[j] <- rbinom(1, 1, sensitivity)
        } else {
          # 无疾病：基于特异性 (1 - 特异性 = 假阳性率)
          screening_result[j] <- rbinom(1, 1, 1 - specificity)
        }
      }
      
      # 5. 计算性能指标
      TP <- sum(disease_status == 1 & screening_result == 1)
      FP <- sum(disease_status == 0 & screening_result == 1)
      TN <- sum(disease_status == 0 & screening_result == 0)
      FN <- sum(disease_status == 1 & screening_result == 0)
      NPV <- ifelse((TN + FN) > 0, TN / (TN + FN), NA)
      # 阳性预测值
      PPV <- ifelse((TP + FP) > 0, TP / (TP + FP), NA)
      
      # 灵敏度
      sensitivity <- TP/(TP+FN)
      specificity <- TN/(TN+FP)
      # 存储结果
      strategy_results$TP[i] <- TP
      strategy_results$FP[i] <- FP
      strategy_results$TN[i] <- TN
      strategy_results$FN[i] <- FN
      strategy_results$PPV[i] <- PPV
      strategy_results$NPV[i] <- NPV
      strategy_results$sensitivity[i] <- sensitivity
      strategy_results$specificity[i] <- specificity
    }
    
    results[[strategy]] <- strategy_results
  }
  
  return(results)
}
