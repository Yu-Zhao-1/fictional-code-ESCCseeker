agresti_se <- function(x, n, conf.level = 0.95) {
  z <- qnorm(1 - (1 - conf.level)/2)
  n_tilde <- n + z^2
  p_tilde <- (x + z^2/2) / n_tilde
  se <- sqrt(p_tilde * (1 - p_tilde) / n_tilde)
  p=x/n
  return(c(p,se))
}
