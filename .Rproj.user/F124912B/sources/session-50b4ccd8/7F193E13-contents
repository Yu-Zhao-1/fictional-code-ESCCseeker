# 完整诊断试验比较分析函数
# 这是你需要的完整代码
compare_diagnostic_tests <- function(d, y1, y2, test_names = c("Test1", "Test2")) {
  library(DTComPair)
  
  # 1. 创建配对表
  tab <- tab.paired(d, y1, y2, testnames = test_names)
  
  # 2. 计算基本指标
  indiv <- acc.paired(tab)
  
  # 3. 灵敏度和特异度比较
  sesp_comp <- sesp.mcnemar(tab)
  
  # 4. 提取数据用于PPV/NPV计算
  a <- tab$diseased[1,1]; b <- tab$diseased[1,2]
  c <- tab$diseased[2,1]; d_val <- tab$diseased[2,2]  # 改名为d_val避免与函数d冲突
  e <- tab$non.diseased[1,1]; f <- tab$non.diseased[1,2]
  g <- tab$non.diseased[2,1]; h <- tab$non.diseased[2,2]
  
  # 5. 计算PPV和检验
  ppv1 <- a / (a + e)
  ppv2 <- (a + c) / (a + c + e + g)
  ppv_diff <- ppv1 - ppv2
  ppv_p <- if(b + e > 0) {
    chi2 <- (abs(b - e) - 0.5)^2 / (b + e)
    pchisq(chi2, df = 1, lower.tail = FALSE)
  } else NA
  
  # 6. 计算NPV和检验
  npv1 <- (d_val + h) / (b + d_val + f + h)
  npv2 <- h / (b + d_val + f + h)
  npv_diff <- npv1 - npv2
  npv_p <- if(g + c > 0) {
    chi2 <- (abs(g - c) - 0.5)^2 / (g + c)
    pchisq(chi2, df = 1, lower.tail = FALSE)
  } else NA
  # 8. 创建结果表
  results <- data.frame(
    Metric = c("Sensitivity", "Specificity", "PPV", "NPV"),
    #Test1 = c(indiv$est[1,1], spec1, ppv1, npv1),
    #Test2 = c(indiv$est[2,1], spec2, ppv2, npv2),
    Difference = c(sesp_comp[["sensitivity"]][["diff"]], sesp_comp[["specificity"]][["diff"]], ppv_diff, npv_diff),
    P_value = c(sesp_comp[["sensitivity"]][["p.value"]], sesp_comp[["specificity"]][["p.value"]], ppv_p, npv_p),
    Significant = c(
      ifelse(sesp_comp[["sensitivity"]][["p.value"]] < 0.05, "Yes", "No"),
      ifelse(sesp_comp[["specificity"]][["p.value"]] < 0.05, "Yes", "No"),
      ifelse(ppv_p < 0.05, "Yes", "No"),
      ifelse(npv_p < 0.05, "Yes", "No")
    )
  )
  
  return(list(
    contingency_table = tab,
    comparison_results = results
  ))
}

