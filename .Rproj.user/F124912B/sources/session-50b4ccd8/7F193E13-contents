agresti_coull_ci <- function(x, n, conf.level = 0.95) {
  z <- qnorm(1 - (1 - conf.level)/2)
  n_tilde <- n + z^2
  p_tilde <- (x + z^2/2) / n_tilde
  se <- sqrt(p_tilde * (1 - p_tilde) / n_tilde)
  lower <- p_tilde - z * se
  upper <- p_tilde + z * se
  p=x/n
  i=paste0(x,"/",n)
  
  return(c(p,lower, upper))
}
