#1. 单变量初步筛选
# 获取所有cg位点的列名
cg_columns <- grep("^cg", colnames(data), value = TRUE)

# 对每个cg位点独立标准化（均值=0，标准差=1）
library(dplyr)

# 假设 cg_columns 是甲基化位点的列名向量
data_zscaled <- data %>%
  mutate(across(all_of(cg_columns), ~ scale(.x)))
# 单变量逻辑回归（case ~ cgXXXX）
univariate_results <- map_dfr(cg_columns, ~{
  model <- glm(
    formula = as.formula(paste("group ~", .x)),
    family = binomial(),
    data = data_zscaled
  )
  tidy(model) %>% 
    filter(term == .x) %>% 
    mutate(
      cg_site = .x,
      OR = exp(estimate),
      OR_95CI = sprintf(
        "%.2f (%.2f-%.2f)", 
        exp(estimate), 
        exp(estimate - 1.96*std.error),
        exp(estimate + 1.96*std.error)
      )
    )
})

# 使用p.adjust进行BH校正（自动跳过NA/Inf值）
univariate_results$FDR <- p.adjust(univariate_results$p.value, method = "BH")

# 筛选显著位点（自动排除NA值）
sig_cgs <- univariate_results %>% 
  filter(FDR < 0.05) %>% 
  pull(cg_site)
#3. 多变量混杂矫正模型
# 构建全调整模型（包含所有协变量）
adjusted_models <- map(sig_cgs, ~{
  glm(
    formula = as.formula(
      paste("group ~", .x, "+ sex + age ")
    ),
    family = binomial(),
    data = data_zscaled
  )
})

# 提取关键结果
adjusted_results <- map2_dfr(adjusted_models, sig_cgs, ~{
  tidy(.x) %>% 
    filter(term == .y) %>% 
    mutate(
      cg_site = .y,
      OR = exp(estimate),
      OR_95CI = paste0(
        round(exp(estimate - 1.96*std.error), 3), "-",
        round(exp(estimate + 1.96*std.error), 3)
      )
    )
})


# 使用p.adjust进行BH校正（自动跳过NA/Inf值）
adjusted_results$FDR <- p.adjust(adjusted_results$p.value, method = "BH")
adjusted_results$p.value <- format(adjusted_results$p.value, scientific = TRUE, digits = 3)
