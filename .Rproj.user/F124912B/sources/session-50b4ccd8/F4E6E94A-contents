# ③. 最优算法===========================
library(lpSolve)

# 定义两个组的最优匹配函数
match_two_groups_lp <- function(data, gender_type, max_age_diff) {
  # 筛选当前性别
  gender_data <- data[data$sex == gender_type, ]
  if (nrow(gender_data) == 0) {
    cat("  ", gender_type, "性别: 无样本，跳过\n")
    return(NULL)
  }
  
  # 拆分为 ESCC 和 Control 两组，按年龄排序（便于调试，非必需）
  escc <- gender_data[gender_data$group == "ESCC", ] %>% arrange(age)
  control <- gender_data[gender_data$group == "Control", ] %>% arrange(age)
  
  if (nrow(escc) == 0 || nrow(control) == 0) {
    cat("  ", gender_type, "性别: ESCC 或 Control 组为空，无法匹配\n")
    return(NULL)
  }
  
  n_escc <- nrow(escc)
  n_control <- nrow(control)
  
  # 构建所有可能的匹配边（年龄差 ≤ max_age_diff 的视为可匹配）
  edges <- list()
  edge_idx <- 1
  for (i in 1:n_escc) {
    for (j in 1:n_control) {
      if (abs(escc$age[i] - control$age[j]) <= max_age_diff) {
        edges[[edge_idx]] <- c(i, j)   # i = ESCC 索引, j = Control 索引
        edge_idx <- edge_idx + 1
      }
    }
  }
  
  if (length(edges) == 0) {
    cat("  ", gender_type, "性别: 没有满足年龄差约束的匹配对，跳过\n")
    return(NULL)
  }
  
  n_edges <- length(edges)
  
  # 构建约束矩阵
  # 约束1: 每个 ESCC 样本最多使用一次
  # 约束2: 每个 Control 样本最多使用一次
  constraints <- matrix(0, nrow = n_escc + n_control, ncol = n_edges)
  rhs <- rep(1, n_escc + n_control)      # 右侧常数（≤1）
  direction <- rep("<=", n_escc + n_control)
  
  for (e in 1:n_edges) {
    i <- edges[[e]][1]   # ESCC 索引
    j <- edges[[e]][2]   # Control 索引
    constraints[i, e] <- 1                     # ESCC 约束行
    constraints[n_escc + j, e] <- 1            # Control 约束行
  }
  
  # 目标函数：每条边的权重为 1（最大化匹配数量）
  objective <- rep(1, n_edges)
  
  # 求解二元整数线性规划（最大匹配）
  solution <- lp("max", objective, constraints, direction, rhs, all.bin = TRUE)
  
  if (solution$status != 0) {
    cat("  ", gender_type, "性别: 求解失败（状态码", solution$status, "）\n")
    return(NULL)
  }
  
  selected_edges <- which(solution$solution == 1)
  if (length(selected_edges) == 0) {
    cat("  ", gender_type, "性别: 无匹配结果\n")
    return(NULL)
  }
  
  # 整理匹配结果
  result_list <- list()
  for (k in seq_along(selected_edges)) {
    edge <- edges[[selected_edges[k]]]
    i <- edge[1]; j <- edge[2]
    result_list[[k]] <- data.frame(
      Pair_ID = paste0(gender_type, "_", sprintf("%03d", k)),
      Gender = gender_type,
      ESCC_Sample = escc$Sample[i],
      NC_Sample = control$Sample[j],
      ESCC_Age = escc$age[i],
      NC_Age = control$age[j],
      Age_Diff = abs(escc$age[i] - control$age[j]),
      stringsAsFactors = FALSE
    )
  }
  
  result <- do.call(rbind, result_list)
  cat("  ", gender_type, "性别: 成功匹配", nrow(result), "对（最大可能匹配数 =", nrow(result), "）\n")
  return(result)
}
