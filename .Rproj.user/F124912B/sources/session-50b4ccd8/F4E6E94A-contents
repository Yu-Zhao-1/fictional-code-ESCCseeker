trr=read_excel("D:/ESCC/芯片图谱/中文/S/ESCC1217.xlsx", sheet = 2)         # 指定工作表索引[^69^]
trr <- column_to_rownames(trr,var = "id")
trr=trr[trr$gg=="yes",-1]
group=ifelse(trr$group=="ESCC",1,0)
trr$group=factor(ifelse(trr$group=="ESCC",1,0))
out=data.frame()
for (h in 7:ncol(trr)) {
  pre=as.numeric(trr[,h])
  id=colnames(trr)[h]
  rt=data.frame(expression=pre,group=trr$group)
  wilcoxTest<-t.test(expression~group,data=rt)
  pvalue=wilcoxTest$p.value
  conGeneMeans=mean(trr[trr$group==0,h])
  treatGeneMeans=mean(trr[trr$group==1,h])
  dif=as.numeric(treatGeneMeans-conGeneMeans)
  out=rbind(out,cbind(id=id,conMean=conGeneMeans,treatMean=treatGeneMeans,dif=dif,pValue=pvalue))
}
out$q=p.adjust(out$pValue,"BH")
design <- model.matrix(~ group)  # 会自动将 group 转换为数值0/1
df=as.data.frame(t(trr[,7:54]))
fit <- lmFit(df, design)
se <- fit$stdev.unscaled[, "group"] * fit$sigma  # group1 是你要比较的那一列
library(winnerscurse)
# 经验贝叶斯校正
input_df=out[,c(1,4)]
input_df$se <- se[match(input_df$id, names(se))]
input_df$dif=as.numeric(input_df$dif)
colnames(input_df)=c("rsid","beta","se")
input_df=rbind(input_df,input_df)
input_df$rsid[49:96]=paste0("cg",1:48)
# winnerscurse 包的 empirical_bayes 函数本身没有设置随机种子的参数
set.seed(123)
corrected_df <- empirical_bayes(summary_data = input_df )
head(corrected_df)
