# 将三个主要模型的关键结果整理成表
# 修复后的 results_table 函数
results_table <- function() {
  # 定义三个模型
  models <- list(
    "Model1 (no Group)" = model1,
    "Model2 (+ Group)" = model2,
    "Model3 (interaction)" = model3
  )
  
  # 定义要提取的系数名称（可能出现的）
  target_terms <- c("logNLR", "GroupESCC", "logNLR:GroupESCC")
  
  # 对每个模型提取系数，并确保包含所有 target_terms（缺失则填 NA）
  results_list <- lapply(names(models), function(name) {
    m <- models[[name]]
    # 使用 broom::tidy 获取系数及置信区间
    coefs <- broom::tidy(m, conf.int = TRUE)
    # 只保留目标项
    coefs <- coefs[coefs$term %in% target_terms, ]
    # 如果某些目标项缺失，手动补全 NA 行
    missing_terms <- setdiff(target_terms, coefs$term)
    if(length(missing_terms) > 0) {
      missing_rows <- data.frame(
        term = missing_terms,
        estimate = NA,
        std.error = NA,
        statistic = NA,
        p.value = NA,
        conf.low = NA,
        conf.high = NA,
        stringsAsFactors = FALSE
      )
      coefs <- rbind(coefs, missing_rows)
    }
    # 添加模型名称列
    coefs$Model <- name
    # 重命名 term 为更友好的展示名称
    coefs$term <- dplyr::recode(coefs$term,
                                "logNLR" = "NLR (log)",
                                "GroupESCC" = "Group (ESCC vs Control)",
                                "logNLR:GroupESCC" = "NLR × Group")
    return(coefs)
  })
  
  # 合并所有模型的结果
  final <- dplyr::bind_rows(results_list) %>%
